{
  "name": "get-set-plus-plus",
  "displayName": "Get Set ++",
  "description": "Instantly generate C++ getters and setters across .hpp and .cpp files. Auto-detects your class name, supports templates, pointers, const members, and inserts code directly into your files.",
  "version": "0.3.2",
  "publisher": "IntisarWaheed",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Intisarw/get-set-plus-plus"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "C++",
    "cpp",
    "getter",
    "setter",
    "code generation",
    "hpp",
    "productivity"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "get-set-plus-plus.Generate",
        "title": "Get Set ++: Generate Getters and Setters",
        "category": "Get Set ++"
      }
    ],
    "keybindings": [
      {
        "command": "get-set-plus-plus.Generate",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
